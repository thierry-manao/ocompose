# ===========================================
# ocompose - Instance Configuration
# ===========================================
# Each instance MUST have a unique PROJECT_NAME and unique ports.

# -------------------------------------------
# Instance Identity
# -------------------------------------------
PROJECT_NAME=myproject
WORKSPACE_USER=developer
WORKSPACE_UID=1000
WORKSPACE_GID=1000
WORKSPACE_SHELL=/bin/bash

# -------------------------------------------
# PHP
# -------------------------------------------
PHP_ENABLED=true
PHP_VERSION=8.3
PHP_EXTENSIONS="mysql mbstring zip gd curl intl xml"
APP_BASE_URL=

# -------------------------------------------
# Virtual Hosts
# -------------------------------------------
# Define one or more vhosts as: port:documentRoot
# Separate multiple vhosts with commas.
# Examples:
#   VHOSTS=8000:public              (single app)
#   VHOSTS=8000:public,8001:api     (app + API)
#   VHOSTS=8000:                    (serve from www/ root)
VHOSTS=8000:

# -------------------------------------------
# MySQL
# -------------------------------------------
MYSQL_ENABLED=true
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app_db
MYSQL_USER=app
MYSQL_PASSWORD=secret
MYSQL_PORT=3306
MYSQL_SEED_FILE=
MYSQL_RESEED_ON_STARTUP=true

# -------------------------------------------
# phpMyAdmin
# -------------------------------------------
PHPMYADMIN_ENABLED=true
PHPMYADMIN_PORT=8080

# -------------------------------------------
# Workspace
# -------------------------------------------
WORKSPACE_SSH_PORT=2222

# -------------------------------------------
# Git Bootstrap
# -------------------------------------------
GIT_REPO=
GIT_BRANCH=
GIT_HTTP_USERNAME=
GIT_HTTP_PASSWORD=
