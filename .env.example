# ===========================================
# ocompose - Instance Configuration
# ===========================================
# Each instance MUST have a unique PROJECT_NAME and unique ports.

# -------------------------------------------
# Instance Identity
# -------------------------------------------
PROJECT_NAME=myproject
WORKSPACE_USER=developer
WORKSPACE_UID=1000
WORKSPACE_GID=1000
WORKSPACE_SHELL=/bin/bash

# -------------------------------------------
# PHP
# -------------------------------------------
PHP_ENABLED=true
PHP_VERSION=8.3
PHP_EXTENSIONS="pdo pdo_mysql mysqli mbstring zip gd curl intl"

# -------------------------------------------
# MySQL
# -------------------------------------------
MYSQL_ENABLED=true
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app_db
MYSQL_USER=app
MYSQL_PASSWORD=secret
MYSQL_PORT=3306

# -------------------------------------------
# phpMyAdmin
# -------------------------------------------
PHPMYADMIN_ENABLED=true
PHPMYADMIN_PORT=8080

# -------------------------------------------
# Workspace
# -------------------------------------------
WORKSPACE_SSH_PORT=2222