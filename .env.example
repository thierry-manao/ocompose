# ===========================================
# ocompose - Instance Configuration
# ===========================================
# Each instance MUST have a unique PROJECT_NAME and unique ports.

# -------------------------------------------
# Instance Identity
# -------------------------------------------
PROJECT_NAME=myproject
WORKSPACE_USER=developer
WORKSPACE_UID=1000
WORKSPACE_GID=1000
WORKSPACE_SHELL=/bin/bash

# -------------------------------------------
# Application Runtime
# -------------------------------------------
# Supported: php, node, python, static (nginx only), none
APP_RUNTIME=php
APP_BASE_URL=

# PHP options (when APP_RUNTIME=php)
PHP_VERSION=8.3
PHP_EXTENSIONS="mysql mbstring zip gd curl intl xml"

# Node.js options (when APP_RUNTIME=node)
NODE_VERSION=20
NODE_COMMAND="node server.js"

# Python options (when APP_RUNTIME=python)
PYTHON_VERSION=3.12
PYTHON_COMMAND="python -m http.server 8000"

# -------------------------------------------
# Virtual Hosts
# -------------------------------------------
# Define one or more vhosts as: port:documentRoot
# Separate multiple vhosts with commas.
# Examples:
#   VHOSTS=8000:public              (single app)
#   VHOSTS=8000:public,8001:api     (app + API)
#   VHOSTS=8000:                    (serve from www/ root)
VHOSTS=8000:

# -------------------------------------------
# Database (external — served by db-docker-server)
# -------------------------------------------
# All instances connect to the external db-docker-server via host.docker.internal.
# Start db-docker-server separately and configure the connection here.
DB_HOST=host.docker.internal
DB_PORT=23306
DB_DATABASE=
DB_USER=root
DB_PASSWORD=root
# When using container name for DB_HOST, specify the network to join (e.g. dbserver_licences_default)
DB_EXTERNAL_NETWORK=

# -------------------------------------------
# Redis (optional)
# -------------------------------------------
REDIS_ENABLED=false
REDIS_VERSION=7
REDIS_PORT=6379

# -------------------------------------------
# Workspace
# -------------------------------------------
WORKSPACE_SSH_PORT=2222

# -------------------------------------------
# Git Bootstrap
# -------------------------------------------
GIT_REPO=
GIT_BRANCH=
GIT_HTTP_USERNAME=
GIT_HTTP_PASSWORD=

# -------------------------------------------
# CodeIgniter 3 Auto-Configuration
# -------------------------------------------
# When CI3 is detected (application/config/ exists), ocompose generates
# a .ocompose.env.php prepend file that injects Docker-compatible values
# into constants and CI config.  Set CI3_ENABLED=false to disable.
CI3_ENABLED=auto
# Map of constant_name=ENV_VAR pairs to override (on top of built-in DB ones).
# Built-in overrides (always active when CI3_ENABLED):
#   BDD_HOST        → MYSQL_HOST
#   BDD_USER        → MYSQL_USER
#   BDD_PWD         → MYSQL_PASSWORD
#   APP_ROOT        → /var/www/html  (or CI3_APP_ROOT)
# Extra constant overrides (comma-separated CONST=ENV pairs):
#   CI3_EXTRA_CONSTANTS="URL_LICENCE=http://licences.local,URL_API=http://api.local"
# For identification app: URL_GED_PERSO (bureau-personnel), URL_ETC, URL_LICENCE
CI3_EXTRA_CONSTANTS=
CI3_APP_ROOT=
CI3_SESSION_SAVE_PATH=
CI3_BASE_URL=
# Auth/identification service URL — overrides all identification.manao.local constants
# (URL_AUTHENTIFICATION, LIEN_GESTION_COMPTE, URL_HEADER_CSS/JS, etc.)
CI3_AUTH_URL=

# -------------------------------------------
# Docker Override Configuration (Auto-Generated)
# -------------------------------------------
# These settings automatically generate docker-compose.override.yml on 'up'
# to mount custom config files into containers.

# Mount custom CI3 configs from docker/config/*.php
CI3_OVERRIDE_CONFIGS=false

# CI3 application type:
#   single            = Single app (mounts to application/ only)
#   dual-webservice   = App + Webservice (mounts to application/ + webservice/v1/)
#   dual-api          = App + API (mounts separate api-*.php to api/application/)
CI3_APP_TYPE=single

# Custom session volume path (e.g. /var/www/compte/sessions)
# Leave empty to use default session handling
CI3_CUSTOM_SESSION_PATH=

# Mount custom nginx config from docker/nginx/default.conf
OVERRIDE_NGINX_CONFIG=false

# Connect php/nginx containers to external dbserver network
CONNECT_TO_DBSERVER=false
