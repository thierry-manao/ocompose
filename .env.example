# ===========================================
# ocompose - Instance Configuration
# ===========================================
# Each instance MUST have a unique PROJECT_NAME and unique ports.

# -------------------------------------------
# Instance Identity
# -------------------------------------------
PROJECT_NAME=myproject
WORKSPACE_USER=developer
WORKSPACE_UID=1000
WORKSPACE_GID=1000
WORKSPACE_SHELL=/bin/bash

# -------------------------------------------
# Application Runtime
# -------------------------------------------
# Supported: php, node, python, static (nginx only), none
APP_RUNTIME=php
APP_BASE_URL=

# PHP options (when APP_RUNTIME=php)
PHP_VERSION=8.3
PHP_EXTENSIONS="mysql mbstring zip gd curl intl xml"

# Node.js options (when APP_RUNTIME=node)
NODE_VERSION=20
NODE_COMMAND="node server.js"

# Python options (when APP_RUNTIME=python)
PYTHON_VERSION=3.12
PYTHON_COMMAND="python -m http.server 8000"

# -------------------------------------------
# Virtual Hosts
# -------------------------------------------
# Define one or more vhosts as: port:documentRoot
# Separate multiple vhosts with commas.
# Examples:
#   VHOSTS=8000:public              (single app)
#   VHOSTS=8000:public,8001:api     (app + API)
#   VHOSTS=8000:                    (serve from www/ root)
VHOSTS=8000:

# -------------------------------------------
# Database
# -------------------------------------------
# Engine: mysql, mariadb, postgres, none
DB_ENGINE=mysql
DB_VERSION=8.0
DB_ROOT_PASSWORD=root
DB_DATABASE=app_db
DB_USER=app
DB_PASSWORD=secret
DB_PORT=3306
DB_SEED_FILE=
DB_RESEED_ON_STARTUP=true

# -------------------------------------------
# Database Admin
# -------------------------------------------
# phpMyAdmin (mysql/mariadb) or pgAdmin (postgres) — auto-selected
DB_ADMIN_ENABLED=true
DB_ADMIN_PORT=8080
# pgAdmin credentials (postgres only)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=secret

# -------------------------------------------
# Redis (optional)
# -------------------------------------------
REDIS_ENABLED=false
REDIS_VERSION=7
REDIS_PORT=6379

# -------------------------------------------
# Workspace
# -------------------------------------------
WORKSPACE_SSH_PORT=2222

# -------------------------------------------
# Git Bootstrap
# -------------------------------------------
GIT_REPO=
GIT_BRANCH=
GIT_HTTP_USERNAME=
GIT_HTTP_PASSWORD=

# -------------------------------------------
# CodeIgniter 3 Auto-Configuration
# -------------------------------------------
# When CI3 is detected (application/config/ exists), ocompose generates
# a .ocompose.env.php prepend file that injects Docker-compatible values
# into constants and CI config.  Set CI3_ENABLED=false to disable.
CI3_ENABLED=auto
# Map of constant_name=ENV_VAR pairs to override (on top of built-in DB ones).
# Built-in overrides (always active when CI3_ENABLED):
#   BDD_HOST        → MYSQL_HOST
#   BDD_USER        → MYSQL_USER
#   BDD_PWD         → MYSQL_PASSWORD
#   APP_ROOT        → /var/www/html  (or CI3_APP_ROOT)
# Extra constant overrides (comma-separated CONST=ENV pairs):
#   CI3_EXTRA_CONSTANTS="URL_LICENCE=http://licences.local,URL_API=http://api.local"
CI3_EXTRA_CONSTANTS=
CI3_APP_ROOT=
CI3_SESSION_SAVE_PATH=
CI3_BASE_URL=
# Auth/identification service URL — overrides all identification.manao.local constants
# (URL_AUTHENTIFICATION, LIEN_GESTION_COMPTE, URL_HEADER_CSS/JS, etc.)
CI3_AUTH_URL=
